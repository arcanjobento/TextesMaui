<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:TextesMaui.ViewModel"
             xmlns:model="clr-namespace:TextesMaui.Models"
             x:DataType="view:MainViewModel"
             x:Class="TextesMaui.MainPage"
             x:Name="ThisPage"
             Title="Gestão de Devedores">

    <Grid RowDefinitions="60,*" RowSpacing="0" BackgroundColor="#F1F5F9">

        <!-- ══════════════════════════════════════════════════════
             HEADER
        ══════════════════════════════════════════════════════ -->
        <Grid ColumnDefinitions="*,Auto"
              BackgroundColor="#1E4E8C"
              Padding="16,0">

            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                <Label Text="Alunos com Dívida"
                       TextColor="White"
                       FontSize="17"
                       FontAttributes="Bold"/>
                <HorizontalStackLayout Spacing="8">
                    <Label Text="{Binding NumberOfDevedoresClasse, StringFormat='{0} devedor(es) nesta classe'}"
                           TextColor="#BFD8F0"
                           FontSize="12"/>
                    <ActivityIndicator IsRunning="{Binding IsBuzzy}"
                                       Color="White"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Ações rápidas de impressão -->
            <ScrollView Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        VerticalOptions="Center">
                <HorizontalStackLayout Spacing="8" Padding="0,8">

                    <!-- Grupo: Esta Classe -->
                    <Border BackgroundColor="#FFFFFF15"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            Padding="10,6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="Esta Classe:"
                                   TextColor="#BFD8F0"
                                   FontSize="11"
                                   VerticalOptions="Center"/>
                            <Border BackgroundColor="#1E4E8C"
                                    StrokeThickness="1"
                                    Stroke="#FFFFFF40"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="10,5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PdfTurmaCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="📄" FontSize="13" VerticalOptions="Center"/>
                                    <Label Text="PDF" TextColor="White" FontSize="12"
                                           FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border BackgroundColor="#1E4E8C"
                                    StrokeThickness="1"
                                    Stroke="#FFFFFF40"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="10,5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PdfTurmaAteProximoMesCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="📄" FontSize="13" VerticalOptions="Center"/>
                                    <Label Text="PDF + Próx. Mês" TextColor="White" FontSize="12"
                                           FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border BackgroundColor="#1E4E8C"
                                    StrokeThickness="1"
                                    Stroke="#FFFFFF40"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="10,5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NotaTurmaUnicaCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="🔔" FontSize="13" VerticalOptions="Center"/>
                                    <Label Text="Nota de Aviso" TextColor="White" FontSize="12"
                                           FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Divisor -->
                    <BoxView WidthRequest="1" BackgroundColor="#FFFFFF30" Margin="4,10"/>

                    <!-- Grupo: Todas as Classes -->
                    <Border BackgroundColor="#FFFFFF15"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            Padding="10,6">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="Todas as Classes:"
                                   TextColor="#BFD8F0"
                                   FontSize="11"
                                   VerticalOptions="Center"/>
                            <Border BackgroundColor="#1E4E8C"
                                    StrokeThickness="1"
                                    Stroke="#FFFFFF40"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="10,5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PdfDevedoresCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="📄" FontSize="13" VerticalOptions="Center"/>
                                    <Label Text="PDF" TextColor="White" FontSize="12"
                                           FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border BackgroundColor="#1E4E8C"
                                    StrokeThickness="1"
                                    Stroke="#FFFFFF40"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="10,5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PdfDevedoresAteProximoMesCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="📄" FontSize="13" VerticalOptions="Center"/>
                                    <Label Text="PDF + Próx. Mês" TextColor="White" FontSize="12"
                                           FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border BackgroundColor="#1E4E8C"
                                    StrokeThickness="1"
                                    Stroke="#FFFFFF40"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="10,5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NotaCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="🔔" FontSize="13" VerticalOptions="Center"/>
                                    <Label Text="Nota de Aviso" TextColor="White" FontSize="12"
                                           FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border BackgroundColor="#1E4E8C"
                                    StrokeThickness="1"
                                    Stroke="#FFFFFF40"
                                    StrokeShape="RoundRectangle 6"
                                    Padding="10,5">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NotaTurmaUnicaTodasTurmasAteProximoMesCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="🔔" FontSize="13" VerticalOptions="Center"/>
                                    <Label Text="Nota + Próx. Mês" TextColor="White" FontSize="12"
                                           FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                        </HorizontalStackLayout>
                    </Border>

                </HorizontalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             CORPO — Classes (esquerda) + Lista Devedores (direita)
        ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              ColumnDefinitions="180,*"
              ColumnSpacing="0">

            <!-- ── PAINEL DE CLASSES ── -->
            <Grid RowDefinitions="Auto,*"
                  BackgroundColor="White">

                <!-- Header classes -->
                <Grid Padding="14,12" BackgroundColor="#F8FAFC">
                    <Label Text="Classes"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#1E293B"/>
                </Grid>

                <!-- Lista de classes -->
                <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding ListaClasses}"
                        Spacing="0"
                        Padding="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="model:Classes">
                                <Border Margin="0,3"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        BackgroundColor="#F1F5F9"
                                        Padding="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type view:MainViewModel}}, Path=ListDevedoresClassCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="0">
                                        <!-- Indicador lateral (aparece quando selecionado) -->
                                        <Border BackgroundColor="#1E4E8C"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 4,0,0,4"
                                                WidthRequest="4"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Nome}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#1E293B"
                                               Padding="12,12"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

            <!-- ── LISTA DE DEVEDORES ── -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*"
                  Margin="1,0,0,0">

                <!-- Header da lista -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                      BackgroundColor="#F8FAFC"
                      Padding="16,10"
                      ColumnSpacing="12">
                    <Label Text="Alunos Devedores"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1E293B"
                           VerticalOptions="Center"/>

                    <!-- Badge total -->
                    <Border Grid.Column="1"
                            BackgroundColor="#FEE2E2"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            Padding="10,5"
                            VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="🔴" FontSize="12" VerticalOptions="Center"/>
                            <Label Text="{Binding NumberOfDevedoresClasse, StringFormat='{0} devedores'}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#D32F2F"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- CollectionView de devedores -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Lista}"
                                SelectedItem="{Binding ClassesSelected}"
                                SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="10"
                                             Padding="20">
                            <Label Text="✅"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label Text="Sem devedores nesta classe"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#94A3B8"
                                   HorizontalOptions="Center"/>
                            <Label Text="Selecione uma classe para ver os devedores"
                                   FontSize="12"
                                   TextColor="#CBD5E1"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:AlunosDevedores">

                            <Grid Padding="12,6">
                                <Border BackgroundColor="White"
                                        StrokeThickness="1"
                                        Stroke="#E2E8F0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="0">

                                    <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="0">

                                        <!-- Barra vermelha lateral -->
                                        <Border BackgroundColor="#D32F2F"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12,0,0,12"
                                                WidthRequest="4"
                                                VerticalOptions="Fill"/>

                                        <!-- Dados do aluno -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             Padding="14,12"
                                                             Spacing="4">
                                            <Label Text="{Binding Nome}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="#1E293B"/>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="📅"
                                                       FontSize="11"
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding MesesDivida}"
                                                       FontSize="12"
                                                       TextColor="#64748B"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Badge número de meses em dívida -->
                                        <Border Grid.Column="2"
                                                BackgroundColor="#FEF2F2"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 0,12,12,0"
                                                WidthRequest="56">
                                            <VerticalStackLayout HorizontalOptions="Center"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <Label Text="🔴"
                                                       FontSize="16"
                                                       HorizontalOptions="Center"/>
                                                <Label Text="Dívida"
                                                       FontSize="9"
                                                       FontAttributes="Bold"
                                                       TextColor="#D32F2F"
                                                       HorizontalOptions="Center"/>
                                            </VerticalStackLayout>
                                        </Border>

                                    </Grid>
                                </Border>
                            </Grid>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>

